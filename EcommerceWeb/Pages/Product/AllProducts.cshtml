@page
@model EcommerceWeb.Pages.Product.AllProductsModel
@{
    ViewData["Title"] = "All Products";
}

<section class="products-page py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">All Products</h1>
    </div>

    <div id="productsMessage" class="alert alert-info d-none" role="alert"></div>
    <div id="productsContainer" class="row g-4"></div>
</section>

@section Scripts {
    <script src="~/Product/all-products.js" asp-append-version="true"></script>
}

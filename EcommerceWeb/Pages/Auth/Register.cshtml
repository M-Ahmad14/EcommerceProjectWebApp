@page
@model EcommerceWeb.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Register";
}
<div class="auth-page">
    <div class="auth-card">
        <h2 class="mb-4 text-center">Create Account</h2>

        <form id="registerForm">

            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" class="form-control" id="name">
                <small class="text-danger" id="nameError"></small>
            </div>

            <div class="mb-3">
                <label class="form-label">Email Address</label>
                <input type="text" class="form-control" id="email">
                <small class="text-danger" id="emailError"></small>
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>

                <div class="input-group">
                    <input type="password" class="form-control" id="password">
                    <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('password', this)">
                        👁
                    </button>
                </div>

                <small class="text-danger" id="passwordError"></small>
            </div>

            <div class="mb-3">
                <label class="form-label">Confirm Password</label>

                <div class="input-group">
                    <input type="password" class="form-control" id="confirmPassword">
                    <button type="button" class="btn btn-outline-secondary" onclick="togglePassword('confirmPassword', this)">
                        👁
                    </button>
                </div>

                <small class="text-danger" id="confirmPasswordError"></small>
            </div>

            <button type="button" class="btn btn-primary w-100" onclick="registerUser()">
                Register
            </button>

        </form>


    </div>
</div>
<!-- jQuery (MUST be before your script) -->

<script src="~/auth/register.js"></script>